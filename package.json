{
  "name": "water-simulation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "validate:build": "npm run build",
    "validate:smoke": "npm run build && npm run test:sim:smoke && npm run screenshots:smoke",
    "validate:standard": "npm run build && npm run test:sim:standard && npm run screenshots:smoke",
    "test:sim": "tsx src/sim/simulationHarness.ts --tier=standard",
    "test:sim:smoke": "tsx src/sim/simulationHarness.ts --tier=smoke",
    "test:sim:standard": "tsx src/sim/simulationHarness.ts --tier=standard",
    "test:sim:full": "tsx src/sim/simulationHarness.ts --tier=full",
    "screenshots": "tsx src/debug/captureScreenshots.ts",
    "screenshots:smoke": "tsx src/debug/captureScreenshots.ts --only=generated-cavern.png,generated-cavern-slice.png,game-generated-cavern-start.png",
    "screenshots:full": "tsx src/debug/captureScreenshots.ts",
    "screenshots:update": "tsx src/debug/captureScreenshots.ts --update-baseline",
    "screenshots:update:smoke": "tsx src/debug/captureScreenshots.ts --update-baseline --only=generated-cavern.png,generated-cavern-slice.png,game-generated-cavern-start.png",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@types/three": "^0.179.0",
    "@types/node": "^24.10.2",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
